{
  "name": "snap-fix",
  "version": "1.0.0",
  "description": "Production-ready code review and auto-fix tool for Node.js projects.",
  "main": "index.js",
  "type": "module",
  "bin": {
    "snap-fix": "./index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "index.js",
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "npm run lint && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "keywords": [
    "cli",
    "production",
    "code-review",
    "fixer",
    "automation"
  ],
  "author": "Rambilas <ram6070246@gmail.com>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ram-sah19/snap-fix.git"
  },
  "bugs": {
    "url": "https://github.com/Ram-sah19/snap-fix/issues"
  },
  "homepage": "https://github.com/Ram-sah19/snap-fix#readme",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^10.0.0",
    "fast-glob": "^3.3.3",
    "inquirer": "^9.2.14"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "vitest": "^4.1.2"
  }
}
